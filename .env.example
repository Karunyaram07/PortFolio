# SMTP Configuration for Contact Form Email Sending
# Copy this file to .env.local and fill in the values below.

# SMTP host (e.g., smtp.gmail.com for Gmail, smtp.mailgun.org for Mailgun, etc.)
SMTP_HOST=smtp.gmail.com

# SMTP port (typically 465 for SSL/secure or 587 for TLS/starttls)
SMTP_PORT=465

# Set to true if using SSL (port 465), or false if using TLS (port 587)
SMTP_SECURE=true

# SMTP authentication username (your sending email address)
SMTP_USER=your-email@gmail.com

# SMTP authentication password
# Note: For Gmail, you MUST use an "App Password" (https://myaccount.google.com/apppasswords), NOT your normal password.
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Optional: The email address that should receive the contact form submissions.
# If left blank, it will default to the primary email specified in data/profile.js.
CONTACT_RECEIVER_EMAIL=sprkarunya986@gmail.com
